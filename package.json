{
  "name": "work-portal",
  "displayName": "仕事ポータル",
  "description": "案件管理・月次処理・目標管理を扱う個人用の仕事ポータル",
  "version": "0.0.1",
  "publisher": "toshimaru-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/toshimaru-dev/si-portal.git"
  },
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "workPortal.open",
        "title": "仕事ポータルを開く"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workPortal",
          "title": "仕事ポータル",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "workPortal": [
        {
          "id": "workPortal.sidebar",
          "name": "仕事ポータル",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "仕事ポータル",
      "properties": {
        "workPortal.dataDir": {
          "type": "string",
          "default": ".work-portal",
          "description": "案件・工数・目標データを保存するフォルダ（ワークスペースルートからの相対パス）"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
